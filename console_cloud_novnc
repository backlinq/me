#!/bin/dash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo "${GREEN}==========================================${NC}"
echo "${GREEN}Ubuntu noVNC Setup -- Simplified & Fast (Webtop XFCE)${NC}"
echo "${GREEN}==========================================${NC}"

# ──────────────────────────────────────────
# STEP 1: System resources
# ──────────────────────────────────────────
get_system_resources() {
    TOTAL_CPUS=`nproc`
    CONTAINER_CPUS=$(( (TOTAL_CPUS * 75 + 99) / 100 ))
    [ "$CONTAINER_CPUS" -lt 1 ] && CONTAINER_CPUS=1

    TOTAL_RAM=`free -m | awk '/^Mem:/{print $2}'`
    CONTAINER_RAM=$(( TOTAL_RAM * 70 / 100 ))
    [ "$CONTAINER_RAM" -lt 2048 ] && CONTAINER_RAM=2048

    echo "${GREEN}System Resources Detected:${NC}"
    echo "   Total CPU cores  : $TOTAL_CPUS"
    echo "   Container CPUs   : $CONTAINER_CPUS"
    echo "   Total RAM        : $TOTAL_RAM MB"
    echo "${YELLOW}Container RAM    : $CONTAINER_RAM MB${NC}"
}

# ──────────────────────────────────────────
# STEP 2: Wait for container
# ──────────────────────────────────────────
wait_for_container() {
    echo "${YELLOW}Waiting for container to be ready...${NC}"
    max_attempts=40
    attempt=0
    while [ $attempt -lt $max_attempts ]; do
        if docker exec ubuntu-novnc pgrep -f "xfce|xfwm|novnc" > /dev/null 2>&1; then
            echo "${GREEN}Container is ready!${NC}"
            return 0
        fi
        attempt=$((attempt + 1))
        echo -n "."
        sleep 3
    done
    echo "${YELLOW}Container ready check timed out, continuing anyway...${NC}"
}

# ──────────────────────────────────────────
# Run steps on HOST
# ──────────────────────────────────────────
get_system_resources

# Check Docker
echo "${YELLOW}Checking Docker installation...${NC}"
if ! command -v docker > /dev/null 2>&1; then
    echo "${YELLOW}Installing Docker...${NC}"
    apt update -y
    apt install -y docker.io
    usermod -aG docker "$USER"
    echo "${GREEN}Docker installed.${NC}"
    echo "${YELLOW}Please log out and back in, then run this script again.${NC}"
    exit 0
fi

# Remove old container if exists
if docker ps -a | grep -q ubuntu-novnc; then
    echo "${YELLOW}Removing existing container...${NC}"
    docker stop ubuntu-novnc 2>/dev/null
    docker rm ubuntu-novnc 2>/dev/null
fi

# Start new Webtop container
echo "${YELLOW}Starting Webtop Ubuntu XFCE container (${CONTAINER_CPUS} CPUs / ${CONTAINER_RAM}MB RAM)...${NC}"
docker run -d \
  -p 8080:3000 \
  -v ~/my-desktop-data:/config \
  -e PUID=1000 \
  -e PGID=1000 \
  -e TZ=Etc/UTC \
  --name ubuntu-novnc \
  --restart unless-stopped \
  --cpus="$CONTAINER_CPUS" \
  --memory="${CONTAINER_RAM}m" \
  --memory-swap="${CONTAINER_RAM}m" \
  lscr.io/linuxserver/webtop:ubuntu-xfce

wait_for_container

# ──────────────────────────────────────────
# Configure apt sources + Base packages
# ──────────────────────────────────────────
echo "${YELLOW}Installing base packages...${NC}"
docker exec ubuntu-novnc sh -c "
  set -e
  apt update -y
  DEBIAN_FRONTEND=noninteractive apt upgrade -y
  DEBIAN_FRONTEND=noninteractive apt install -y \
    firefox konsole neofetch python3-tk python3-pip \
    xclip mousepad dbus-x11 libgtk-3-0 \
    file-roller curl wget build-essential
  pip3 install --user pyte
  echo 'Base packages installed'
"

# ==================================================================
# OPTIONAL PROGRAMS - EASY TO ENABLE/DISABLE WITH #
# ==================================================================

# ==================== CODE EDITORS (VS Code + Sublime Text + Geany) ====================
# Remove the # below to install Code Editors

# echo "${YELLOW}Installing Code Editors (VS Code, Sublime Text, Geany)...${NC}"
docker exec ubuntu-novnc sh -c "
  set -e
  add-apt-repository --remove ppa:webupd8team/brackets 2>/dev/null || true

  wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | tee /etc/apt/trusted.gpg.d/microsoft.gpg > /dev/null
  add-apt-repository -y \"deb [arch=amd64] https://packages.microsoft.com/repos/vscode stable main\"

  wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | apt-key add -
  add-apt-repository -y \"deb https://download.sublimetext.com/ apt/stable/\"

  apt update -y
  DEBIAN_FRONTEND=noninteractive apt install -y code sublime-text geany
  echo 'Code editors installed'
"

# VS Code extensions
# echo "${YELLOW}Installing VS Code extensions...${NC}"
docker exec ubuntu-novnc sh -c "
  if command -v code > /dev/null 2>&1; then
    code --no-sandbox --user-data-dir=/root/.vscode-root \
      --install-extension formulahendry.code-runner \
      --install-extension ms-python.python \
      --install-extension ritwickdey.liveserver
    echo 'VS Code extensions installed'
  fi
"


# ==================== PASSWORD MANAGERS (Bitwarden + Proton Pass) ====================
# Remove the # below to install Bitwarden and Proton Pass

# echo "${YELLOW}Installing Bitwarden and Proton Pass (latest versions)...${NC}"
docker exec ubuntu-novnc sh -c "
  set -e
  cd /tmp

  echo 'Downloading latest Bitwarden...'
  wget -q -O bitwarden.deb \"https://bitwarden.com/download/?app=desktop&platform=linux&variant=deb\"
  DEBIAN_FRONTEND=noninteractive apt install -fy ./bitwarden.deb
  rm -f bitwarden.deb

  echo 'Downloading latest Proton Pass...'
  wget -q -O proton-pass.deb \"https://proton.me/download/PassDesktop/linux/x64/ProtonPass.deb\"
  DEBIAN_FRONTEND=noninteractive apt install -fy ./proton-pass.deb
  rm -f proton-pass.deb

  echo 'Bitwarden and Proton Pass installed'
"


# ──────────────────────────────────────────
# Install RustDesk (Always installed)
# ──────────────────────────────────────────
echo "${YELLOW}Installing RustDesk...${NC}"
docker exec ubuntu-novnc sh -c "
  set -e
  VER=\`curl -s https://api.github.com/repos/rustdesk/rustdesk/releases/latest | grep -oP '\"tag_name\": \"\K[^\"]+'\`
  [ -z \"\$VER\" ] && VER='1.3.0'
  wget -q https://github.com/rustdesk/rustdesk/releases/download/\$VER/rustdesk-\$VER-x86_64.deb -O /tmp/rustdesk.deb
  DEBIAN_FRONTEND=noninteractive apt install -fy /tmp/rustdesk.deb
  rm -f /tmp/rustdesk.deb
"

# ──────────────────────────────────────────
# Create desktop files
# ──────────────────────────────────────────
echo "${YELLOW}Setting up desktop shortcuts...${NC}"
docker exec ubuntu-novnc sh -c "
  mkdir -p /root/Desktop

  cat > /root/Desktop/firefox.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Firefox
Exec=firefox
Icon=firefox
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/konsole.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Konsole
Exec=konsole
Icon=utilities-terminal
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/rustdesk.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=RustDesk
Exec=rustdesk
Icon=rustdesk
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/vscode.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Visual Studio Code
Exec=code --no-sandbox --user-data-dir=/root/.vscode-root
Icon=vscode
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/bitwarden.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Bitwarden
Exec=bitwarden
Icon=bitwarden
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/proton-pass.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Proton Pass
Exec=proton-pass
Icon=proton-pass
Terminal=false
Type=Application
DESK

  chmod +x /root/Desktop/*.desktop

  mkdir -p /etc/xdg/autostart
  cat > /etc/xdg/autostart/konsole.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=Konsole
Exec=konsole
X-GNOME-Autostart-enabled=true
AUTO

  cat > /etc/xdg/autostart/rustdesk.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=RustDesk
Exec=rustdesk
X-GNOME-Autostart-enabled=true
AUTO
"

# ──────────────────────────────────────────
# Launch apps
# ──────────────────────────────────────────
echo "${YELLOW}Launching applications...${NC}"
docker exec ubuntu-novnc sh -c "
  export DISPLAY=:1
  sleep 5
  konsole &
  rustdesk &
  sleep 3
  firefox &
"

EXTERNAL_IP=`curl -s ifconfig.me 2>/dev/null || echo "YOUR_VM_IP"`

echo "${GREEN}==========================================${NC}"
echo "${GREEN}ALL DONE!${NC}"
echo "${GREEN}==========================================${NC}"
echo "   Desktop URL : ${YELLOW}http://$EXTERNAL_IP:8080${NC}"
echo ""
echo "${GREEN}Core Installed:${NC}"
echo "   • Firefox, Konsole, RustDesk"
echo ""
echo "${YELLOW}Tip:${NC} Remove the '#' from the lines under CODE EDITORS or PASSWORD MANAGERS to enable optional programs."
echo ""
echo "${GREEN}==========================================${NC}"