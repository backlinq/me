#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${GREEN}==========================================${NC}"
echo -e "${GREEN}Ubuntu noVNC Setup -- Simplified & Fast${NC}"
echo -e "${GREEN}==========================================${NC}"

# ──────────────────────────────────────────
# STEP 1: System resources
# ──────────────────────────────────────────
get_system_resources() {
    TOTAL_CPUS=$(nproc)
    CONTAINER_CPUS=$(( (TOTAL_CPUS * 75 + 99) / 100 ))
    [ "$CONTAINER_CPUS" -lt 1 ] && CONTAINER_CPUS=1

    TOTAL_RAM=$(free -m | awk '/^Mem:/{print $2}')
    CONTAINER_RAM=$(( TOTAL_RAM * 70 / 100 ))
    [ "$CONTAINER_RAM" -lt 2048 ] && CONTAINER_RAM=2048

    echo -e "${GREEN}System Resources Detected:${NC}"
    echo "   Total CPU cores  : $TOTAL_CPUS"
    echo "   Container CPUs   : $CONTAINER_CPUS"
    echo "   Total RAM        : $TOTAL_RAM MB"
    echo -e "   ${YELLOW}Container RAM    : $CONTAINER_RAM MB${NC}"
}

# ──────────────────────────────────────────
# STEP 2: Wait for container
# ──────────────────────────────────────────
wait_for_container() {
    echo -e "${YELLOW}Waiting for container to be ready...${NC}"
    local max_attempts=30
    local attempt=0
    while [ $attempt -lt $max_attempts ]; do
        if docker exec ubuntu-novnc pgrep -f "Xvfb|openbox" > /dev/null 2>&1; then
            echo -e "${GREEN}Container is ready!${NC}"
            return 0
        fi
        attempt=$((attempt + 1))
        echo -n "."
        sleep 2
    done
    echo -e "${YELLOW}Container ready check timed out, continuing anyway...${NC}"
}

# ──────────────────────────────────────────
# Run steps on HOST
# ──────────────────────────────────────────
get_system_resources

# Check Docker
echo -e "${YELLOW}Checking Docker installation...${NC}"
if ! command -v docker &> /dev/null; then
    echo -e "${YELLOW}Installing Docker...${NC}"
    sudo apt update -y
    sudo apt install -y docker.io
    sudo usermod -aG docker $USER
    echo -e "${GREEN}Docker installed.${NC}"
    echo -e "${YELLOW}Please log out and back in, then run this script again.${NC}"
    exit 0
fi

# Remove old container if exists
if docker ps -a | grep -q ubuntu-novnc; then
    echo -e "${YELLOW}Removing existing container...${NC}"
    docker stop ubuntu-novnc 2>/dev/null
    docker rm ubuntu-novnc 2>/dev/null
fi

# Start container
echo -e "${YELLOW}Starting container (${CONTAINER_CPUS} CPUs / ${CONTAINER_RAM}MB RAM)...${NC}"
docker run -d \
  -p 8080:80 \
  -v ~/my-desktop-data:/shareVolume \
  -v /dev/shm:/dev/shm \
  --name ubuntu-novnc \
  --restart unless-stopped \
  --cpus="$CONTAINER_CPUS" \
  --memory="${CONTAINER_RAM}m" \
  --memory-swap="${CONTAINER_RAM}m" \
  wenoptics/ubuntu-desktop-novnc

wait_for_container

# ──────────────────────────────────────────
# Configure apt sources
# ──────────────────────────────────────────
echo -e "${YELLOW}Configuring apt sources...${NC}"
docker exec ubuntu-novnc bash -c "
  set -e
  rm -f /etc/apt/sources.list.d/google-chrome.list*

  CODENAME=\$(lsb_release -cs)

  cat > /etc/apt/sources.list << SOURCES
deb http://archive.ubuntu.com/ubuntu \$CODENAME           main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu \$CODENAME-updates   main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu \$CODENAME-backports main restricted universe multiverse
deb http://security.ubuntu.com/ubuntu \$CODENAME-security main restricted universe multiverse
SOURCES

  apt update -y
  echo 'Apt sources configured'
"

# ──────────────────────────────────────────
# Install base packages
# ──────────────────────────────────────────
echo -e "${YELLOW}Installing base packages...${NC}"
docker exec ubuntu-novnc bash -c "
  rm -f /etc/apt/sources.list.d/google-chrome.list*

  DEBIAN_FRONTEND=noninteractive apt upgrade -y
  DEBIAN_FRONTEND=noninteractive apt install -y \
    firefox konsole neofetch python3-tk python3-pip \
    xclip mousepad dbus-x11 libgtk-3-0 \
    file-roller curl wget build-essential

  pip3 install --user pyte
  echo 'Base packages installed'
"

# ──────────────────────────────────────────
# Install Rust
# ──────────────────────────────────────────
echo -e "${YELLOW}Installing Rust...${NC}"
docker exec ubuntu-novnc bash -c "
  # Install Rust using rustup
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  
  # Add cargo to PATH for current session
  source \$HOME/.cargo/env
  
  # Add Rust to PATH permanently
  echo 'export PATH=\$PATH:\$HOME/.cargo/bin' >> /root/.bashrc
  echo 'export PATH=\$PATH:\$HOME/.cargo/bin' >> /root/.profile
  
  echo 'Rust installed successfully'
"

# ──────────────────────────────────────────
# Install Windows cross-compilation support
# ──────────────────────────────────────────
echo -e "${YELLOW}Setting up Windows cross-compilation...${NC}"
docker exec ubuntu-novnc bash -c "
  source \$HOME/.cargo/env
  
  # Add Windows target for Rust
  /root/.cargo/bin/rustup target add x86_64-pc-windows-gnu
  
  # Install MinGW-w64 for cross-compilation
  DEBIAN_FRONTEND=noninteractive apt update
  DEBIAN_FRONTEND=noninteractive apt install -y mingw-w64
  
  # Verify installation
  echo 'Installed Windows targets:'
  /root/.cargo/bin/rustc --print target-list | grep windows || echo 'Windows targets available'
  
  echo 'Windows cross-compilation support installed'
"

# ──────────────────────────────────────────
# Create Rust compiler GUI script
# ──────────────────────────────────────────
echo -e "${YELLOW}Creating Rust compiler GUI...${NC}"
docker exec ubuntu-novnc bash -c "
  cat > /root/Desktop/rust_compiler.py << 'PYTHON'
#!/usr/bin/env python3
import tkinter as tk
from tkinter import scrolledtext, filedialog, messagebox
import subprocess
import os

class RustCompiler:
    def __init__(self, root):
        self.root = root
        self.root.title(\"Rust Compiler\")
        self.root.geometry(\"800x600\")
        
        self.rustc_path = self.find_rustc()
        
        tk.Label(root, text=\"Rust Source Code:\", font=('Arial', 10, 'bold')).pack(anchor='w', padx=10, pady=5)
        self.code = scrolledtext.ScrolledText(root, height=15, font=('Courier', 10))
        self.code.pack(fill='both', expand=True, padx=10, pady=5)
        
        btn_frame = tk.Frame(root)
        btn_frame.pack(pady=10)
        
        tk.Button(btn_frame, text=\"Compile (Linux)\", command=lambda: self.compile(\"linux\"), bg='#4CAF50', fg='white', width=15).pack(side='left', padx=5)
        tk.Button(btn_frame, text=\"Compile (Windows EXE)\", command=lambda: self.compile(\"windows\"), bg='#2196F3', fg='white', width=18).pack(side='left', padx=5)
        tk.Button(btn_frame, text=\"Load .rs File\", command=self.load_file, width=12).pack(side='left', padx=5)
        tk.Button(btn_frame, text=\"Save .rs File\", command=self.save_file, width=12).pack(side='left', padx=5)
        tk.Button(btn_frame, text=\"Clear\", command=self.clear_all, width=8).pack(side='left', padx=5)
        
        tk.Label(root, text=\"Output:\", font=('Arial', 10, 'bold')).pack(anchor='w', padx=10, pady=5)
        self.output = scrolledtext.ScrolledText(root, height=12, font=('Courier', 10))
        self.output.pack(fill='both', expand=True, padx=10, pady=5)
        
        self.status = tk.Label(root, text=\"Ready\", relief='sunken', anchor='w')
        self.status.pack(fill='x', padx=10, pady=5)
        
        if os.path.exists('hello.rs'):
            with open('hello.rs', 'r') as f:
                self.code.insert('1.0', f.read())
        
        if not self.rustc_path:
            self.status.config(text=\"ERROR: Rust not found\")
    
    def find_rustc(self):
        try:
            result = subprocess.run(['which', 'rustc'], capture_output=True, text=True)
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip()
        except:
            pass
        
        paths = ['/root/.cargo/bin/rustc', '/home/ubuntu/.cargo/bin/rustc', '/usr/local/bin/rustc']
        for path in paths:
            if os.path.exists(path):
                return path
        return None
    
    def compile(self, target):
        if not self.rustc_path:
            messagebox.showerror(\"Error\", \"Rust compiler not found\")
            return
        
        code = self.code.get('1.0', 'end-1c')
        if not code.strip():
            messagebox.showerror(\"Error\", \"No code to compile\")
            return
        
        if target == \"windows\":
            filename = filedialog.asksaveasfilename(title=\"Save Windows EXE\", defaultextension=\".exe\", initialfile=\"program.exe\", filetypes=[(\"Windows Executable\", \"*.exe\"), (\"All files\", \"*.*\")])
            if not filename:
                return
            cmd = [self.rustc_path, '--target', 'x86_64-pc-windows-gnu', '/tmp/temp.rs', '-o', filename]
        else:
            filename = filedialog.asksaveasfilename(title=\"Save Linux Binary\", defaultextension=\"\", initialfile=\"program\", filetypes=[(\"Executable\", \"*\"), (\"All files\", \"*.*\")])
            if not filename:
                return
            cmd = [self.rustc_path, '/tmp/temp.rs', '-o', filename]
        
        self.output.delete('1.0', 'end')
        self.output.insert('end', f\"Compiling to: {filename}\\n\" + \"-\"*50 + \"\\n\")
        self.status.config(text=\"Compiling...\")
        self.root.update()
        
        with open('/tmp/temp.rs', 'w') as f:
            f.write(code)
        
        try:
            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode == 0:
                self.output.insert('end', \"Compilation successful!\\n\")
                self.status.config(text=f\"Binary created: {filename}\")
                if target == \"linux\" and os.path.exists(filename):
                    os.chmod(filename, 0o755)
                messagebox.showinfo(\"Success\", f\"Binary saved to: {filename}\")
            else:
                self.output.insert('end', \"Compilation failed!\\n\" + result.stderr)
                self.status.config(text=\"Compilation failed\")
                messagebox.showerror(\"Error\", result.stderr)
        except Exception as e:
            self.output.insert('end', f\"Error: {str(e)}\\n\")
    
    def load_file(self):
        filename = filedialog.askopenfilename(filetypes=[(\"Rust files\", \"*.rs\"), (\"All files\", \"*.*\")])
        if filename:
            with open(filename, 'r') as f:
                self.code.delete('1.0', 'end')
                self.code.insert('1.0', f.read())
            self.status.config(text=f\"Loaded: {filename}\")
    
    def save_file(self):
        filename = filedialog.asksaveasfilename(defaultextension=\".rs\", filetypes=[(\"Rust files\", \"*.rs\"), (\"All files\", \"*.*\")])
        if filename:
            with open(filename, 'w') as f:
                f.write(self.code.get('1.0', 'end-1c'))
            self.status.config(text=f\"Saved: {filename}\")
    
    def clear_all(self):
        self.code.delete('1.0', 'end')
        self.output.delete('1.0', 'end')

if __name__ == \"__main__\":
    root = tk.Tk()
    app = RustCompiler(root)
    root.mainloop()
PYTHON

  chmod +x /root/Desktop/rust_compiler.py
"

# ──────────────────────────────────────────
# Create hello.rs example
# ──────────────────────────────────────────
echo -e "${YELLOW}Creating hello.rs example...${NC}"
docker exec ubuntu-novnc bash -c "
  cat > /root/Desktop/hello.rs << 'RUST'
fn main() {
    println!(\"Hello, World from Rust!\");
}
RUST
"

# ──────────────────────────────────────────
# Install RustDesk
# ──────────────────────────────────────────
echo -e "${YELLOW}Installing RustDesk...${NC}"
docker exec ubuntu-novnc bash -c "
  set -e
  VER=\$(curl -s https://api.github.com/repos/rustdesk/rustdesk/releases/latest | grep -oP '\"tag_name\": \"\K[^\"]+')
  [ -z \"\$VER\" ] && VER='1.3.0'
  wget -q https://github.com/rustdesk/rustdesk/releases/download/\$VER/rustdesk-\$VER-x86_64.deb -O /tmp/rustdesk.deb
  DEBIAN_FRONTEND=noninteractive apt install -fy /tmp/rustdesk.deb
  rm -f /tmp/rustdesk.deb
"

# ──────────────────────────────────────────
# Create desktop files
# ──────────────────────────────────────────
echo -e "${YELLOW}Setting up desktop...${NC}"
docker exec ubuntu-novnc bash -c "
  mkdir -p /root/Desktop

  cat > /root/Desktop/firefox.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Firefox
Exec=firefox
Icon=firefox
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/konsole.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Konsole
Exec=konsole
Icon=utilities-terminal
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/rustdesk.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=RustDesk
Exec=rustdesk
Icon=rustdesk
Terminal=false
Type=Application
DESK

  cat > /root/Desktop/rust-compiler.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Rust Compiler
Exec=python3 /root/Desktop/rust_compiler.py
Icon=utilities-terminal
Terminal=false
Type=Application
DESK

  chmod +x /root/Desktop/*.desktop

  # Autostart entries
  mkdir -p /etc/xdg/autostart
  cat > /etc/xdg/autostart/konsole.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=Konsole
Exec=konsole
X-GNOME-Autostart-enabled=true
AUTO

  cat > /etc/xdg/autostart/rustdesk.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=RustDesk
Exec=rustdesk
X-GNOME-Autostart-enabled=true
AUTO
"

# ──────────────────────────────────────────
# Launch apps (Firefox last)
# ──────────────────────────────────────────
echo -e "${YELLOW}Launching applications...${NC}"
docker exec ubuntu-novnc bash -c "
  export DISPLAY=:1
  sleep 3
  konsole &
  rustdesk &
  sleep 2
  firefox &
"

EXTERNAL_IP=$(curl -s ifconfig.me 2>/dev/null || echo "YOUR_VM_IP")

echo -e "${GREEN}==========================================${NC}"
echo -e "${GREEN}ALL DONE!${NC}"
echo -e "${GREEN}==========================================${NC}"
echo -e "   Desktop URL : ${YELLOW}http://$EXTERNAL_IP:8080${NC}"
echo ""
echo -e "${GREEN}Resources:${NC}"
echo -e "   CPUs     : ${YELLOW}$CONTAINER_CPUS${NC} of $TOTAL_CPUS"
echo -e "   RAM      : ${YELLOW}${CONTAINER_RAM}MB${NC} of ${TOTAL_RAM}MB"
echo ""
echo -e "${GREEN}Installed:${NC}"
echo -e "   • Rust with Windows cross-compilation (mingw-w64)"
echo -e "   • Rust Compiler GUI (desktop shortcut)"
echo -e "   • Firefox, Konsole, RustDesk"
echo ""
echo -e "${YELLOW}To compile Rust to Windows EXE:${NC}"
echo -e "   1. Open 'Rust Compiler' from desktop"
echo -e "   2. Click 'Compile (Windows EXE)'"
echo -e "   3. Save the .exe file"
echo ""
echo -e "${GREEN}==========================================${NC}"
