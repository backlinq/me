#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${GREEN}==========================================${NC}"
echo -e "${GREEN}Ubuntu noVNC Setup -- Simplified & Fast${NC}"
echo -e "${GREEN}==========================================${NC}"

# ──────────────────────────────────────────
# STEP 1: System resources
# ──────────────────────────────────────────
get_system_resources() {
    TOTAL_CPUS=$(nproc)
    CONTAINER_CPUS=$(( (TOTAL_CPUS * 75 + 99) / 100 ))
    [ "$CONTAINER_CPUS" -lt 1 ] && CONTAINER_CPUS=1

    TOTAL_RAM=$(free -m | awk '/^Mem:/{print $2}')
    CONTAINER_RAM=$(( TOTAL_RAM * 70 / 100 ))
    [ "$CONTAINER_RAM" -lt 2048 ] && CONTAINER_RAM=2048

    echo -e "${GREEN}System Resources Detected:${NC}"
    echo "   Total CPU cores  : $TOTAL_CPUS"
    echo "   Container CPUs   : $CONTAINER_CPUS"
    echo "   Total RAM        : $TOTAL_RAM MB"
    echo -e "   ${YELLOW}Container RAM    : $CONTAINER_RAM MB${NC}"
}

# ──────────────────────────────────────────
# STEP 2: Wait for container
# ──────────────────────────────────────────
wait_for_container() {
    echo -e "${YELLOW}Waiting for container to be ready...${NC}"
    local max_attempts=30
    local attempt=0
    while [ $attempt -lt $max_attempts ]; do
        if docker exec ubuntu-novnc pgrep -f "Xvfb|openbox" > /dev/null 2>&1; then
            echo -e "${GREEN}Container is ready!${NC}"
            return 0
        fi
        attempt=$((attempt + 1))
        echo -n "."
        sleep 2
    done
    echo -e "${YELLOW}Container ready check timed out, continuing anyway...${NC}"
}

# ──────────────────────────────────────────
# Run steps on HOST
# ──────────────────────────────────────────
get_system_resources

# Check Docker
echo -e "${YELLOW}Checking Docker installation...${NC}"
if ! command -v docker &> /dev/null; then
    echo -e "${YELLOW}Installing Docker...${NC}"
    sudo apt update -y
    sudo apt install -y docker.io
    sudo usermod -aG docker $USER
    echo -e "${GREEN}Docker installed.${NC}"
    echo -e "${YELLOW}Please log out and back in, then run this script again.${NC}"
    exit 0
fi

# Remove old container if exists
if docker ps -a | grep -q ubuntu-novnc; then
    echo -e "${YELLOW}Removing existing container...${NC}"
    docker stop ubuntu-novnc 2>/dev/null
    docker rm ubuntu-novnc 2>/dev/null
fi

# Start container
echo -e "${YELLOW}Starting container (${CONTAINER_CPUS} CPUs / ${CONTAINER_RAM}MB RAM)...${NC}"
docker run -d \
  -p 8080:80 \
  -v ~/my-desktop-data:/shareVolume \
  -v /dev/shm:/dev/shm \
  --name ubuntu-novnc \
  --restart unless-stopped \
  --cpus="$CONTAINER_CPUS" \
  --memory="${CONTAINER_RAM}m" \
  --memory-swap="${CONTAINER_RAM}m" \
  wenoptics/ubuntu-desktop-novnc

wait_for_container

# ──────────────────────────────────────────
# Configure apt sources
# ──────────────────────────────────────────
echo -e "${YELLOW}Configuring apt sources...${NC}"
docker exec ubuntu-novnc bash -c "
  set -e
  rm -f /etc/apt/sources.list.d/google-chrome.list*

  CODENAME=\$(lsb_release -cs)

  cat > /etc/apt/sources.list << SOURCES
deb http://archive.ubuntu.com/ubuntu \$CODENAME           main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu \$CODENAME-updates   main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu \$CODENAME-backports main restricted universe multiverse
deb http://security.ubuntu.com/ubuntu \$CODENAME-security main restricted universe multiverse
SOURCES

  apt update -y
  echo 'Apt sources configured'
"

# ──────────────────────────────────────────
# Install base packages
# ──────────────────────────────────────────
echo -e "${YELLOW}Installing base packages...${NC}"
docker exec ubuntu-novnc bash -c "
  rm -f /etc/apt/sources.list.d/google-chrome.list*

  DEBIAN_FRONTEND=noninteractive apt upgrade -y
  DEBIAN_FRONTEND=noninteractive apt install -y \
    firefox konsole neofetch python3-tk python3-pip \
    xclip mousepad dbus-x11 libgtk-3-0 \
    file-roller curl wget build-essential

  pip3 install --user pyte
  echo 'Base packages installed'
"

# ──────────────────────────────────────────
# OPTIONAL: Install Code Editors (VS Code + Sublime Text + Geany)
# ──────────────────────────────────────────
# You can comment out the entire block below if you don't need these editors

echo -e "${YELLOW}Installing Code Editors (VS Code, Sublime Text, Geany)...${NC}"
echo -e "${YELLOW}→ Comment out this whole section when not needed.${NC}"

docker exec ubuntu-novnc bash -c "
  set -e

  add-apt-repository --remove ppa:webupd8team/brackets 2>/dev/null || true

  # VS Code repository
  wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | tee /etc/apt/trusted.gpg.d/microsoft.gpg > /dev/null
  add-apt-repository -y \"deb [arch=amd64] https://packages.microsoft.com/repos/vscode stable main\"

  # Sublime Text repository
  wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | apt-key add -
  add-apt-repository -y \"deb https://download.sublimetext.com/ apt/stable/\"

  apt update -y
  DEBIAN_FRONTEND=noninteractive apt install -y code sublime-text geany

  echo 'Code editors installed'
"

# VS Code extensions
echo -e "${YELLOW}Installing VS Code extensions...${NC}"
docker exec ubuntu-novnc bash -c "
  if command -v code &> /dev/null; then
    code --no-sandbox --user-data-dir=/root/.vscode-root \
      --install-extension formulahendry.code-runner \
      --install-extension ms-python.python \
      --install-extension ritwickdey.liveserver
    echo 'VS Code extensions installed'
  fi
"

# ──────────────────────────────────────────
# Install Password Managers: Bitwarden + Proton Pass (Latest)
# ──────────────────────────────────────────
echo -e "${YELLOW}Installing Bitwarden and Proton Pass (latest versions)...${NC}"

docker exec ubuntu-novnc bash -c "
  set -e
  cd /tmp

  # Bitwarden - Official latest .deb
  echo 'Downloading latest Bitwarden...'
  wget -q -O bitwarden.deb \"https://bitwarden.com/download/?app=desktop&platform=linux&variant=deb\"
  DEBIAN_FRONTEND=noninteractive apt install -fy ./bitwarden.deb
  rm -f bitwarden.deb

  # Proton Pass - Official latest .deb (always fetches current version)
  echo 'Downloading latest Proton Pass...'
  wget -q -O proton-pass.deb \"https://proton.me/download/PassDesktop/linux/x64/ProtonPass.deb\"
  DEBIAN_FRONTEND=noninteractive apt install -fy ./proton-pass.deb
  rm -f proton-pass.deb

  echo 'Bitwarden and Proton Pass installed successfully'
"

# ──────────────────────────────────────────
# Create desktop files
# ──────────────────────────────────────────
echo -e "${YELLOW}Setting up desktop shortcuts...${NC}"
docker exec ubuntu-novnc bash -c "
  mkdir -p /root/Desktop

  # Firefox
  cat > /root/Desktop/firefox.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Firefox
Exec=firefox
Icon=firefox
Terminal=false
Type=Application
DESK

  # Konsole
  cat > /root/Desktop/konsole.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Konsole
Exec=konsole
Icon=utilities-terminal
Terminal=false
Type=Application
DESK

  # RustDesk
  cat > /root/Desktop/rustdesk.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=RustDesk
Exec=rustdesk
Icon=rustdesk
Terminal=false
Type=Application
DESK

  # Visual Studio Code
  cat > /root/Desktop/vscode.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Visual Studio Code
Exec=code --no-sandbox --user-data-dir=/root/.vscode-root
Icon=vscode
Terminal=false
Type=Application
DESK

  # Bitwarden
  cat > /root/Desktop/bitwarden.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Bitwarden
Exec=bitwarden
Icon=bitwarden
Terminal=false
Type=Application
DESK

  # Proton Pass
  cat > /root/Desktop/proton-pass.desktop << 'DESK'
[Desktop Entry]
Version=1.0
Name=Proton Pass
Exec=proton-pass
Icon=proton-pass
Terminal=false
Type=Application
DESK

  chmod +x /root/Desktop/*.desktop

  # Autostart
  mkdir -p /etc/xdg/autostart
  cat > /etc/xdg/autostart/konsole.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=Konsole
Exec=konsole
X-GNOME-Autostart-enabled=true
AUTO

  cat > /etc/xdg/autostart/rustdesk.desktop << 'AUTO'
[Desktop Entry]
Type=Application
Name=RustDesk
Exec=rustdesk
X-GNOME-Autostart-enabled=true
AUTO
"

# ──────────────────────────────────────────
# Launch apps
# ──────────────────────────────────────────
echo -e "${YELLOW}Launching applications...${NC}"
docker exec ubuntu-novnc bash -c "
  export DISPLAY=:1
  sleep 3
  konsole &
  rustdesk &
  sleep 2
  firefox &
"

EXTERNAL_IP=$(curl -s ifconfig.me 2>/dev/null || echo "YOUR_VM_IP")

echo -e "${GREEN}==========================================${NC}"
echo -e "${GREEN}ALL DONE!${NC}"
echo -e "${GREEN}==========================================${NC}"
echo -e "   Desktop URL : ${YELLOW}http://$EXTERNAL_IP:8080${NC}"
echo ""
echo -e "${GREEN}Resources:${NC}"
echo -e "   CPUs     : ${YELLOW}$CONTAINER_CPUS${NC} of $TOTAL_CPUS"
echo -e "   RAM      : ${YELLOW}${CONTAINER_RAM}MB${NC} of ${TOTAL_RAM}MB"
echo ""
echo -e "${GREEN}Installed:${NC}"
echo -e "   • Firefox, Konsole, RustDesk"
echo -e "   • VS Code + extensions (optional)"
echo -e "   • Sublime Text, Geany (optional)"
echo -e "   • Bitwarden (latest)"
echo -e "   • Proton Pass (latest)"
echo ""
echo -e "${YELLOW}Desktop Shortcuts created for:${NC}"
echo -e "   Firefox | Konsole | RustDesk | VS Code | Bitwarden | Proton Pass"
echo ""
echo -e "${GREEN}==========================================${NC}"